# ─────────────────────────────────────────────────────────────
# NextUp — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── AI / LLM ──────────────────────────────────────────────────
# Your OpenAI API key (or any OpenAI-compatible provider key).
# LEAVE BLANK to run in MOCK MODE — full app, zero API calls.
OPENAI_API_KEY=

# OpenAI-compatible base URL (optional — defaults to OpenAI).
# Examples:
#   OpenAI:   https://api.openai.com/v1  (default, can omit)
#   Groq:     https://api.groq.com/openai/v1
#   Together: https://api.together.xyz/v1
#   Ollama:   http://localhost:11434/v1
OPENAI_BASE_URL=

# Model to use (optional — defaults to gpt-4o-mini).
# Groq example: llama3-8b-8192
# Together example: mistralai/Mixtral-8x7B-Instruct-v0.1
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
# Defaults to ./nextup.db in the project root.
# For production: use Turso (libSQL) or PlanetScale (MySQL) instead.
DB_PATH=./nextup.db

# ── Feature Flags ─────────────────────────────────────────────
# Force mock AI mode even if OPENAI_API_KEY is set (useful for testing).
USE_MOCK_AI=false
